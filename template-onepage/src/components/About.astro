---
interface Props {
  businessName: string;
  founded?: number;
  profile: string;
  differentials: string[];
  photos: string[];
  label?: string;
}

const { businessName, founded, profile, differentials, photos, label = 'Quem somos' } = Astro.props;
const photo = photos?.[1] || photos?.[0];
const yearsActive = founded ? new Date().getFullYear() - founded : null;
---

<section id="sobre" class="section bg-secondary text-cream overflow-hidden" data-section-blur>
  <div class="site-shell">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- Foto -->
      <div class="lg:col-span-5 relative">
        {photo && (
          <div class="relative aspect-[4/5] overflow-hidden rounded-lg">
            <img
              src={photo}
              alt={`Ambiente da ${businessName}`}
              class="w-full h-full object-cover"
              data-parallax="0.3"
              loading="lazy"
            />
          </div>
        )}

        {yearsActive && (
          <div class="absolute -bottom-6 -right-4 md:-right-6 bg-primary text-secondary px-6 py-5 rounded-lg reveal-up">
            <div class="font-display text-5xl md:text-6xl leading-none">{yearsActive}</div>
            <div class="text-[10px] uppercase tracking-widest mt-1">Anos de história</div>
          </div>
        )}
      </div>

      <!-- Conteúdo -->
      <div class="lg:col-span-7 lg:pt-8">

        <span class="text-xs uppercase tracking-[0.25em] text-cream/50 reveal-up mb-5 inline-flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-primary"></span>
          {label}
        </span>

        <h2 class="font-display text-big uppercase mb-8">
          <span class="reveal-mask block"><span>{businessName}</span></span>
        </h2>

        <p class="text-lg md:text-xl leading-relaxed text-cream/85 mb-10 reveal-up">
          {profile}
        </p>

        <!-- Diferenciais -->
        {differentials && differentials.length > 0 && (
          <ul class="border-t border-cream/15" data-stagger>
            {differentials.map((item) => (
              <li class="reveal-up border-b border-cream/15 py-4 flex gap-4 items-start" data-stagger-item>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="text-primary shrink-0 mt-1.5">
                  <path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span class="text-base md:text-lg leading-snug">{item}</span>
              </li>
            ))}
          </ul>
        )}

      </div>

    </div>
  </div>
</section>
