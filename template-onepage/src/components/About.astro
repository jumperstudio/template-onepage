---
// About.astro
// Usa differentials do client.json. Não inventar diferenciais.

interface Props {
  businessName: string;
  founded: number;
  profile: string;
  differentials: string[];
  photos: string[];
}

const { businessName, founded, profile, differentials, photos } = Astro.props;
const aboutPhoto = photos?.[1] || photos?.[0] || null;
const currentYear = new Date().getFullYear();
const yearsActive = currentYear - founded;
---

<section id="sobre" class="section bg-white">
  <div class="container">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Imagem -->
      {aboutPhoto && (
        <div class="relative">
          <img
            src={aboutPhoto}
            alt={`${businessName} — ambiente`}
            class="w-full aspect-[4/5] object-cover rounded-card"
            loading="lazy"
          />
          <!-- Badge de anos -->
          <div class="absolute -bottom-6 -right-6 bg-primary text-white rounded-card p-6 text-center shadow-card">
            <p class="font-display text-display-lg font-extrabold uppercase leading-none">{yearsActive}</p>
            <p class="font-body text-sm font-medium">anos de<br/>experiência</p>
          </div>
        </div>
      )}

      <!-- Conteúdo -->
      <div class={!aboutPhoto ? 'lg:col-span-2' : ''}>
        <p class="font-body text-sm font-semibold uppercase tracking-widest text-primary mb-2">
          Quem somos
        </p>
        <h2 class="font-display text-display-lg font-bold uppercase text-secondary mb-6">
          {businessName}
        </h2>

        {profile && (
          <p class="font-body text-gray-600 text-lg leading-relaxed mb-8">
            {profile}
          </p>
        )}

        <!-- Diferenciais -->
        {differentials && differentials.length > 0 && (
          <ul class="space-y-4">
            {differentials.map((item) => (
              <li class="flex gap-4 items-start">
                <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center mt-0.5" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"/>
                  </svg>
                </span>
                <span class="font-body text-gray-700">{item}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

    </div>
  </div>
</section>
