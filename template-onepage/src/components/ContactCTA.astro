---
interface Props {
  businessName: string;
  phone: string;
  whatsapp: string;
  email: string;
  address: string;
  hours: Record<string, string>;
  primaryCta: 'whatsapp' | 'phone' | 'email';
  social: Record<string, string>;
  label?: string;
  title?: string;
  description?: string;
}

const {
  businessName, phone, whatsapp, email, address, hours, primaryCta, social,
  label = 'Contato',
  title = 'Vamos conversar?',
  description = 'Agende seu horário ou tire dúvidas. Respondemos rapidamente.',
} = Astro.props;

const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp.replace(/\D/g,'')}?text=${encodeURIComponent('Olá, vim pelo site e gostaria de mais informações.')}` : null;
const phoneUrl = phone ? `tel:${phone.replace(/\D/g,'')}` : null;
const emailUrl = email ? `mailto:${email}` : null;

const ctaHref = primaryCta === 'whatsapp' && whatsappUrl ? whatsappUrl : (phoneUrl || emailUrl || '#');
const ctaLabel = primaryCta === 'whatsapp' ? 'Conversar no WhatsApp' : (primaryCta === 'phone' ? 'Ligar agora' : 'Enviar e-mail');
---

<section id="contato" class="section bg-primary text-secondary relative overflow-hidden" data-section-blur>

  <!-- Palavra grande no fundo (decorativo) -->
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
    <h2 class="font-display text-[22vw] leading-none text-secondary/10 whitespace-nowrap">CONTATO</h2>
  </div>

  <div class="max-w-6xl mx-auto px-6 md:px-10 relative z-10">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-3">
        <span class="text-xs uppercase tracking-[0.25em] text-secondary/60 reveal-up inline-flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-secondary"></span>
          {label}
        </span>
      </div>
      <h2 class="lg:col-span-9 font-display text-big uppercase">
        <span class="reveal-mask block"><span>{title}</span></span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- CTA principal + contatos -->
      <div class="lg:col-span-6 reveal-up">
        <p class="text-lg md:text-xl leading-relaxed mb-10 text-secondary/85 max-w-md">
          {description}
        </p>

        <a href={ctaHref} target="_blank" rel="noopener" class="btn-primary !bg-secondary !text-cream">
          {ctaLabel}
          <span class="arrow inline-flex">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
              <path d="M5 15L15 5M15 5H7M15 5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
        </a>

        <div class="mt-10 space-y-3" data-stagger>
          {phone && (
            <a href={phoneUrl} class="reveal-up flex gap-4 items-center text-secondary/80 hover:text-secondary transition-colors" data-stagger-item>
              <span class="text-xs uppercase tracking-widest text-secondary/50 w-20">Telefone</span>
              <span class="text-base">{phone}</span>
            </a>
          )}
          {email && (
            <a href={emailUrl} class="reveal-up flex gap-4 items-center text-secondary/80 hover:text-secondary transition-colors" data-stagger-item>
              <span class="text-xs uppercase tracking-widest text-secondary/50 w-20">E-mail</span>
              <span class="text-base">{email}</span>
            </a>
          )}
          {address && (
            <a href={`https://maps.google.com/?q=${encodeURIComponent(address)}`} target="_blank" rel="noopener"
               class="reveal-up flex gap-4 items-start text-secondary/80 hover:text-secondary transition-colors" data-stagger-item>
              <span class="text-xs uppercase tracking-widest text-secondary/50 w-20 mt-1">Endereço</span>
              <span class="text-base">{address}</span>
            </a>
          )}
        </div>
      </div>

      <!-- Horários + social -->
      <div class="lg:col-span-6 lg:col-start-8 reveal-up">

        {Object.keys(hours).length > 0 && (
          <div class="border border-secondary/20 p-8 lg:p-10 mb-6 rounded-lg">
            <h3 class="text-xs uppercase tracking-widest mb-5">Funcionamento</h3>
            <dl class="space-y-3" data-stagger>
              {Object.entries(hours).map(([day, time]) => (
                <div class="reveal-up flex justify-between items-baseline border-b border-secondary/15 pb-3" data-stagger-item>
                  <dt class="text-sm text-secondary/70">{day}</dt>
                  <dd class="font-display text-lg uppercase">{time}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        {social?.instagram && (
          <a href={social.instagram} target="_blank" rel="noopener" class="btn-outline w-full justify-center">
            Siga no Instagram
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 13L13 3M13 3H5M13 3V11" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </a>
        )}

      </div>

    </div>

  </div>
</section>
