---
interface Props {
  businessName: string;
  phone: string;
  whatsapp: string;
  email: string;
  address: string;
  hours: Record<string, string>;
  primaryCta: 'whatsapp' | 'phone' | 'email';
  social: Record<string, string>;
  label?: string;
  title?: string;
  description?: string;
}

const {
  businessName, phone, whatsapp, email, address, hours, primaryCta, social,
  label = 'Contato',
  title = 'Vamos conversar?',
  description = 'Agende seu horário ou tire dúvidas. Respondemos rapidamente.',
} = Astro.props;

const whatsappUrl = whatsapp ? `https://wa.me/${whatsapp.replace(/\D/g,'')}?text=${encodeURIComponent('Olá, vim pelo site e gostaria de mais informações.')}` : null;
const phoneUrl = phone ? `tel:${phone.replace(/\D/g,'')}` : null;
const emailUrl = email ? `mailto:${email}` : null;

const ctaHref = primaryCta === 'whatsapp' && whatsappUrl ? whatsappUrl : (phoneUrl || emailUrl || '#');
const ctaLabel = primaryCta === 'whatsapp' ? 'Conversar no WhatsApp' : (primaryCta === 'phone' ? 'Ligar agora' : 'Enviar e-mail');

const contactItems = [
  phone && {
    label: 'Telefone',
    value: phone,
    href: phoneUrl,
  },
  email && {
    label: 'E-mail',
    value: email,
    href: emailUrl,
  },
  address && {
    label: 'Endereço',
    value: address,
    href: `https://maps.google.com/?q=${encodeURIComponent(address)}`,
    external: true,
  },
].filter(Boolean);
---

<section id="contato" class="section contact-section bg-primary text-secondary relative overflow-hidden" data-section-blur>
  <div class="site-shell relative z-10">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mb-12 md:mb-16">
      <div class="lg:col-span-3">
        <span class="text-xs uppercase tracking-[0.25em] text-secondary/65 reveal-up inline-flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-secondary"></span>
          {label}
        </span>
      </div>
      <div class="lg:col-span-9">
        <h2 class="font-display text-big uppercase">
          <span class="reveal-mask block"><span>{title}</span></span>
        </h2>
        <p class="reveal-up mt-5 max-w-2xl text-base md:text-lg leading-relaxed text-secondary/75">
          {description}
        </p>
      </div>
    </div>

    <div class="contact-stage">

      <div class="contact-action reveal-up">
        <div class="contact-action__headline">
          <span class="contact-action__eyebrow">Atendimento direto</span>
          <h3 class="contact-action__title">
            Vamos marcar o<br /> próximo horário?
          </h3>
        </div>

        <div class="contact-action__aside">
          <p class="contact-action__text">
            Tire dúvidas, confirme disponibilidade e escolha o melhor horário pelo canal principal.
          </p>

          <a href={ctaHref} target="_blank" rel="noopener" class="contact-main-button">
            {primaryCta === 'whatsapp' && (
              <svg class="contact-main-button__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M4.8 20.2L5.9 16.85A8.05 8.05 0 1 1 7.2 18.15L4.8 20.2Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9.15 7.55C9.42 7.28 9.86 7.32 10.08 7.64L10.84 8.78C11.01 9.03 10.96 9.37 10.73 9.57L10.28 9.96C10.74 10.85 11.44 11.55 12.34 12.02L12.75 11.58C12.96 11.35 13.3 11.31 13.55 11.48L14.68 12.25C15 12.47 15.04 12.9 14.77 13.18C14.18 13.78 13.3 14.04 12.49 13.75C10.76 13.13 8.9 11.27 8.28 9.54C7.99 8.72 8.26 8.43 9.15 7.55Z" fill="currentColor"/>
              </svg>
            )}
            <span class="contact-main-button__label">{ctaLabel}</span>
            <svg class="contact-main-button__arrow" width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M5 15L15 5M15 5H7M15 5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="contact-directory">
        {contactItems.length > 0 && (
          <div class="contact-list" data-stagger>
            <div class="contact-list__heading reveal-up">
              <h3 class="contact-block-title">Canais</h3>
              {social?.instagram && (
                <a href={social.instagram} target="_blank" rel="noopener" class="contact-instagram-link">
                  <span class="contact-instagram-link__content">
                    <svg class="contact-instagram-link__icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <rect x="1.25" y="1.25" width="9.5" height="9.5" rx="2.75" stroke="currentColor" stroke-width="1.25"/>
                      <circle cx="6" cy="6" r="2.2" stroke="currentColor" stroke-width="1.25"/>
                      <circle cx="8.75" cy="3.25" r="0.65" fill="currentColor"/>
                    </svg>
                    <span class="contact-instagram-link__text">Siga nosso perfil no Instagram</span>
                  </span>
                  <svg class="contact-instagram-link__arrow" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M5 15L15 5M15 5H7M15 5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </a>
              )}
            </div>
            {contactItems.map((item, index) => (
              <a
                href={item.href}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener' : undefined}
                class="contact-row reveal-up"
                data-stagger-item
              >
                <span class="contact-row__index">{String(index + 1).padStart(2, '0')}</span>
                <span class="contact-row__label">{item.label}</span>
                <span class="contact-row__value">{item.value}</span>
                <svg class="contact-row__arrow" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 15L15 5M15 5H7M15 5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </a>
            ))}
          </div>
        )}

        <div class="contact-side reveal-up">
          {Object.keys(hours).length > 0 && (
            <div class="contact-hours">
              <h3 class="contact-block-title">Funcionamento</h3>
              <dl class="contact-hours__list" data-stagger>
                {Object.entries(hours).map(([day, time]) => (
                  <div class="contact-hours__row reveal-up" data-stagger-item>
                    <dt>{day}</dt>
                    <dd>{time}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )}
        </div>
      </div>

    </div>

  </div>
</section>
