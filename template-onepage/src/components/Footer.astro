---
import { getMapsUrl, getPhoneUrl } from '../lib/links';

interface Props {
  businessName: string;
  shortName?: string;
  address?: string;
  phone?: string;
  social?: Record<string, string>;
}

const { businessName, shortName, address, phone, social } = Astro.props;
const year = new Date().getFullYear();
const mapsUrl = getMapsUrl(address);
const phoneUrl = getPhoneUrl(phone);
---

<footer class="bg-secondary text-cream">

  <!-- Big name -->
  <div class="border-y border-cream/10 py-12 md:py-16 overflow-hidden">
    <div class="site-shell">
      <h2 class="font-display text-huge uppercase leading-[0.9] whitespace-nowrap overflow-hidden">
        <span class="reveal-mask block"><span>{shortName || businessName}</span></span>
      </h2>
    </div>
  </div>

  <!-- Info row -->
  <div class="site-shell py-10 grid grid-cols-1 md:grid-cols-[minmax(0,1.7fr)_minmax(0,0.65fr)_minmax(0,0.65fr)] gap-8 text-sm">

    {address && mapsUrl && (
      <div class="min-w-0">
        <div class="text-xs uppercase tracking-widest text-cream/40 mb-2">Endereço</div>
        <a href={mapsUrl} target="_blank" rel="noopener" class="inline-flex max-w-full items-center gap-2 text-cream/80 hover:text-primary transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 opacity-80">
            <path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
            <circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.7"/>
          </svg>
          <span class="whitespace-nowrap overflow-hidden text-ellipsis">{address}</span>
        </a>
      </div>
    )}

    {phone && phoneUrl && (
      <div>
        <div class="text-xs uppercase tracking-widest text-cream/40 mb-2">Telefone</div>
        <a href={phoneUrl} class="inline-flex items-center gap-2 text-cream/80 hover:text-primary transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 opacity-80">
            <path d="M7 4h3l1.5 4-2 1.2a10.8 10.8 0 0 0 5.3 5.3l1.2-2 4 1.5v3c0 1.1-.9 2-2 2A15 15 0 0 1 5 6c0-1.1.9-2 2-2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
          </svg>
          {phone}
        </a>
      </div>
    )}

    {social?.instagram && (
      <div>
        <div class="text-xs uppercase tracking-widest text-cream/40 mb-2">Redes</div>
        <a href={social.instagram} target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-cream/80 hover:text-primary transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0 opacity-80">
            <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"/>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"/>
          </svg>
          Instagram
        </a>
      </div>
    )}

  </div>

  <!-- Bottom -->
  <div class="site-shell py-6 border-t border-cream/10 flex flex-col md:flex-row justify-between items-center gap-3 text-xs uppercase tracking-widest text-cream/30">
    <span>© {year} {businessName}. Todos os direitos reservados.</span>
    <a href="#inicio" class="footer-top-link" aria-label="Voltar ao topo da página">
      <span>Topo</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M8 12V4M8 4L4.5 7.5M8 4L11.5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>

</footer>
