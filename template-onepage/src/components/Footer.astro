---
// Footer.astro

interface Props {
  businessName: string;
  address: string;
  phone: string;
  social: Record<string, string>;
}

const { businessName, address, phone, social } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-secondary py-10">
  <div class="container">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">

      <div>
        <p class="font-display text-xl font-bold uppercase text-white">{businessName}</p>
        {address && <p class="font-body text-sm text-white/40 mt-1">{address}</p>}
      </div>

      <div class="flex gap-6 items-center">
        {social?.instagram && (
          <a
            href={social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-white/40 hover:text-primary transition-colors"
          >
            Instagram
          </a>
        )}
        {phone && (
          <a
            href={`tel:${phone.replace(/\D/g,'')}`}
            class="font-body text-sm text-white/40 hover:text-primary transition-colors"
          >
            {phone}
          </a>
        )}
      </div>

    </div>

    <div class="border-t border-white/10 mt-8 pt-6">
      <p class="font-body text-xs text-white/30">
        © {year} {businessName}. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>
