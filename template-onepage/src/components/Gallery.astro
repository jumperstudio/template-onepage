---
// Gallery.astro
// Renderiza fotos do client.json. Se não houver fotos (< 2), não renderiza.

interface Props {
  photos: string[];
  businessName: string;
}

const { photos, businessName } = Astro.props;
if (!photos || photos.length < 2) return;

// Máximo 6 fotos na galeria
const galleryPhotos = photos.slice(0, 6);
---

<section id="galeria" class="section bg-gray-50">
  <div class="container">

    <div class="mb-12">
      <p class="font-body text-sm font-semibold uppercase tracking-widest text-primary mb-2">
        Nosso espaço
      </p>
      <h2 class="font-display text-display-lg font-bold uppercase text-secondary">
        Galeria
      </h2>
    </div>

    <!-- Grid masonry simples -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {galleryPhotos.map((photo, i) => (
        <div class={`overflow-hidden rounded-card ${i === 0 ? 'col-span-2 md:col-span-1 md:row-span-2' : ''}`}>
          <img
            src={photo}
            alt={`${businessName} — foto ${i + 1}`}
            class="w-full h-full object-cover aspect-square hover:scale-105 transition-transform duration-slow"
            loading="lazy"
          />
        </div>
      ))}
    </div>

  </div>
</section>
