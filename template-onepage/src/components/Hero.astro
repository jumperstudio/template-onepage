---
interface Props {
  businessName: string;
  tagline: string;
  shortName?: string;
  ctaLabel: string;
  ctaHref: string;
  heroImage?: string;
  city?: string;
  neighborhood?: string;
  founded?: number;
  shortDescription?: string;
}

const {
  businessName,
  tagline,
  shortName,
  ctaLabel,
  ctaHref,
  heroImage,
  city,
  neighborhood,
  founded,
  shortDescription,
} = Astro.props;

const yearsActive = founded ? new Date().getFullYear() - founded : null;
const words = tagline.split(' ');
const location = [neighborhood, city].filter(Boolean).join(', ');
---

<section id="inicio" class="relative min-h-screen bg-secondary text-cream overflow-hidden flex flex-col">

  <!-- IMAGEM DE FUNDO (BACKGROUND) -->
  {heroImage && (
    <div class="absolute inset-0 z-10 overflow-hidden">
      <img
        src={heroImage}
        alt={businessName}
        class="w-full h-full object-cover"
        data-parallax="0.3"
      />
      <!-- Vinheta / Overlay escuro para legibilidade do texto -->
      <div class="absolute inset-0 bg-gradient-to-b from-secondary/90 via-secondary/70 to-secondary/95"></div>
    </div>
  )}

  <!-- HEADER -->
  <header class="relative z-30 px-6 md:px-10 py-6 flex justify-between items-center">

    <a href="#inicio" class="font-display text-xl uppercase tracking-tight" data-hero-fade>
      {shortName || businessName}
    </a>

    <nav class="hidden md:flex gap-8 items-center text-sm" data-hero-fade>
      <a href="#servicos"   class="hover:text-primary transition-colors">Serviços</a>
      <a href="#sobre"      class="hover:text-primary transition-colors">Sobre</a>
      <a href="#trabalhos"  class="hover:text-primary transition-colors">Galeria</a>
      <a href="#contato"    class="hover:text-primary transition-colors">Contato</a>
    </nav>

    <a href={ctaHref} target="_blank" rel="noopener" class="btn-primary !py-2.5 !px-5 !text-sm" data-hero-fade>
      Agendar
      <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M3 11L11 3M11 3H4M11 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </a>

  </header>

  <!-- CONTEÚDO PRINCIPAL (SOBREPOSTO À IMAGEM) -->
  <div class="relative z-20 flex-1 flex flex-col justify-center px-6 md:px-10 py-12 lg:py-20 max-w-5xl">

    <!-- Tag superior -->
    {location && (
      <div class="reveal-mask mb-8">
        <span class="block">
          <span class="inline-flex items-center gap-3 text-xs uppercase tracking-[0.2em] text-cream/60">
            <span class="inline-block w-8 h-px bg-primary"></span>
            {location}
          </span>
        </span>
      </div>
    )}

    <!-- HEADLINE -->
    <h1 class="font-display uppercase text-huge mb-10">
      {words.map((word) => (
        <span class="hero-mask inline-block overflow-hidden align-bottom">
          <span data-hero-line class="inline-block mr-[0.15em]">{word}</span>
        </span>
      ))}
    </h1>

    <!-- Descrição -->
    {shortDescription && (
      <p class="text-lg md:text-xl leading-relaxed text-cream/80 max-w-3xl mb-10 reveal-up">
        {shortDescription}
      </p>
    )}

    <!-- CTA + Stats -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-8" data-hero-fade>
      <a href={ctaHref} target="_blank" rel="noopener" class="btn-primary">
        {ctaLabel}
        <span class="arrow inline-flex">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <path d="M5 15L15 5M15 5H7M15 5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
      </a>
    </div>

  </div>

  <!-- FOOTER do Hero -->
  <div class="relative z-20 border-t border-cream/10 px-6 md:px-10 py-5 flex justify-between items-center text-xs uppercase tracking-widest text-cream/40 gap-6" data-hero-fade>
    <span class="inline-flex items-center gap-2">
      Conheça a {shortName || businessName}
      <svg class="animate-float-down w-3 h-3 text-cream/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </span>
    <span class="hidden md:inline">{businessName}</span>
  </div>

</section>
