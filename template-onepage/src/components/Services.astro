---
interface ServiceItem {
  name: string;
  description: string;
  target?: string;
}

interface Props {
  items: ServiceItem[];
  label?: string;
  title?: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  items,
  label = 'Serviços',
  title = 'O que oferecemos',
  ctaHref = '#contato',
  ctaLabel = 'Consultar serviço',
} = Astro.props;
if (!items || items.length === 0) return;

const opensInNewTab = ctaHref.startsWith('http');
---

<section id="servicos" class="section bg-cream overflow-hidden" data-section-blur>
  <div class="site-shell">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mb-12 md:mb-14">

      <div class="lg:col-span-3">
        <span class="text-xs uppercase tracking-[0.25em] text-secondary/50 reveal-up inline-flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-primary"></span>
          {label}
        </span>
      </div>

      <div class="lg:col-span-9 max-w-4xl">
        <h2 class="font-display text-big uppercase">
          <span class="reveal-mask block"><span>{title}</span></span>
        </h2>
        <p class="reveal-up mt-5 max-w-2xl text-base md:text-lg text-secondary/65 leading-relaxed">
          Opções claras para resolver o que você precisa com orientação, cuidado e resultado.
        </p>
      </div>

    </div>

    <div class="services-grid" data-stagger>
      {items.map((service, index) => (
        <a
          href={ctaHref}
          target={opensInNewTab ? '_blank' : undefined}
          rel={opensInNewTab ? 'noopener' : undefined}
          class="service-card reveal-up"
          data-stagger-item
          aria-label={`${ctaLabel}: ${service.name}`}
        >
          <div class="service-card__top">
            <span class="service-card__number">
              {String(index + 1).padStart(2, '0')}
            </span>

            <span class="service-card__arrow" aria-hidden="true">
              <svg width="19" height="19" viewBox="0 0 20 20" fill="none">
                <path d="M5 15L15 5M15 5H7M15 5V13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </span>
          </div>

          <div class="service-card__content">
            <h3 class="service-card__title">
              {service.name}
            </h3>

            <p class="service-card__description">
              {service.description}
            </p>
          </div>

          {service.target && (
            <p class="service-card__target">
              <span>Indicado para</span>
              {service.target}
            </p>
          )}
        </a>
      ))}
    </div>

  </div>
</section>
