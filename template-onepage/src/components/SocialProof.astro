---
interface Testimonial {
  name: string;
  role?: string;
  text: string;
  rating: number;
}

interface NumberStat {
  value: string;
  label: string;
}

interface ProcessStep {
  title: string;
  description: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  type?: 'testimonials' | 'numbers' | 'process' | 'faq';
  testimonials?: Testimonial[];
  numbers?: NumberStat[];
  process?: ProcessStep[];
  faq?: FaqItem[];
  label?: string;
  title?: string;
}

const {
  type = 'testimonials',
  testimonials = [],
  numbers = [],
  process = [],
  faq = [],
  label,
  title,
} = Astro.props;

const hasData =
  (type === 'testimonials' && testimonials.length > 0) ||
  (type === 'numbers' && numbers.length > 0) ||
  (type === 'process' && process.length > 0) ||
  (type === 'faq' && faq.length > 0);

if (!hasData) return;

const defaultLabel = {
  testimonials: 'Depoimentos',
  numbers: 'Em números',
  process: 'Como funciona',
  faq: 'Dúvidas frequentes',
};

const defaultTitle = {
  testimonials: 'O que dizem sobre nós',
  numbers: 'Resultados que falam por si',
  process: 'Simples do início ao fim',
  faq: 'Respondemos as principais dúvidas',
};

const sectionLabel = label || defaultLabel[type];
const sectionTitle = title || defaultTitle[type];
---

<section id="depoimentos" class="section bg-cream" data-section-blur>
  <div class="site-shell">

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-3">
        <span class="text-xs uppercase tracking-[0.25em] text-secondary/50 reveal-up inline-flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-primary"></span>
          {sectionLabel}
        </span>
      </div>
      <h2 class="lg:col-span-9 font-display text-big uppercase">
        <span class="reveal-mask block"><span>{sectionTitle}</span></span>
      </h2>
    </div>

    {type === 'testimonials' && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
        {testimonials.map((item) => (
          <article
            class="reveal-up bg-secondary text-cream p-8 lg:p-10 rounded-lg transition-transform duration-700 ease-expo hover:-translate-y-2"
            data-stagger-item
          >
            <svg width="32" height="26" viewBox="0 0 40 32" class="text-primary mb-6" fill="currentColor" aria-hidden="true">
              <path d="M0 32V19.2C0 8.6 5.6 1.4 16.8 0v6.4c-5.6 1.4-8.4 5.2-8.4 11.4H16V32H0zm22.4 0V19.2C22.4 8.6 28 1.4 39.2 0v6.4c-5.6 1.4-8.4 5.2-8.4 11.4h7.6V32H22.4z"/>
            </svg>

            <p class="text-base md:text-lg leading-relaxed mb-8 text-cream/90">
              {item.text}
            </p>

            <div class="flex gap-1 mb-5" aria-label={`${item.rating} de 5 estrelas`}>
              {Array.from({ length: item.rating }).map(() => (
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="text-primary" aria-hidden="true">
                  <path d="M8 1l1.8 3.6L14 5.6l-3 2.9.7 4.1L8 10.5l-3.7 2.1.7-4.1-3-2.9 4.2-.9L8 1z"/>
                </svg>
              ))}
            </div>

            <footer class="border-t border-cream/15 pt-4">
              <div class="font-display text-lg uppercase">{item.name}</div>
              {item.role && (
                <div class="text-xs uppercase tracking-widest text-cream/50 mt-1">{item.role}</div>
              )}
            </footer>
          </article>
        ))}
      </div>
    )}

    {type === 'numbers' && (
      <div class="social-proof-numbers" data-stagger>
        {numbers.map((stat) => (
          <div class="social-proof-stat reveal-up" data-stagger-item>
            <div class="social-proof-stat__value">{stat.value}</div>
            <div class="social-proof-stat__label">{stat.label}</div>
          </div>
        ))}
      </div>
    )}

    {type === 'process' && (
      <div class="social-proof-process" data-stagger>
        {process.map((step, index) => (
          <div class="social-proof-step reveal-up" data-stagger-item>
            <div class="social-proof-step__number">{String(index + 1).padStart(2, '0')}</div>
            <h3 class="social-proof-step__title">{step.title}</h3>
            <p class="social-proof-step__description">{step.description}</p>
          </div>
        ))}
      </div>
    )}

    {type === 'faq' && (
      <div class="social-proof-faq" data-stagger>
        {faq.map((item) => (
          <details class="social-proof-question reveal-up" data-stagger-item>
            <summary>
              <span>{item.question}</span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    )}

  </div>
</section>
