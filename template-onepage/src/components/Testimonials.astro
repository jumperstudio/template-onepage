---
// Testimonials.astro
// Usa depoimentos REAIS do client.json. Mínimo 1. Não inventar.

interface Testimonial {
  name: string;
  text: string;
  rating: number;
}

interface Props {
  items: Testimonial[];
}

const { items } = Astro.props;
if (!items || items.length === 0) return;
---

<section id="depoimentos" class="section bg-secondary">
  <div class="container">

    <div class="mb-12">
      <p class="font-body text-sm font-semibold uppercase tracking-widest text-primary mb-2">
        O que dizem
      </p>
      <h2 class="font-display text-display-lg font-bold uppercase text-white">
        Depoimentos
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item) => (
        <blockquote class="bg-white/5 border border-white/10 rounded-card p-8">

          <!-- Estrelas -->
          <div class="flex gap-1 mb-4" aria-label={`${item.rating} de 5 estrelas`}>
            {Array.from({ length: item.rating }).map(() => (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" class="text-primary" aria-hidden="true">
                <path d="M8 1l1.8 3.6L14 5.6l-3 2.9.7 4.1L8 10.5l-3.7 2.1.7-4.1-3-2.9 4.2-.9L8 1z"/>
              </svg>
            ))}
          </div>

          <p class="font-body text-white/80 text-base leading-relaxed mb-6 italic">
            "{item.text}"
          </p>

          <footer class="font-body text-sm font-semibold text-primary">
            — {item.name}
          </footer>

        </blockquote>
      ))}
    </div>

  </div>
</section>
