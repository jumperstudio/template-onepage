---
interface Testimonial {
  name: string;
  role?: string;
  text: string;
  rating: number;
}

interface Props {
  items: Testimonial[];
  label?: string;
  title?: string;
}

const { items, label = 'Depoimentos', title = 'O que dizem sobre nós' } = Astro.props;
if (!items || items.length === 0) return;
---

<section id="depoimentos" class="section bg-cream" data-section-blur>
  <div class="max-w-6xl mx-auto px-6 md:px-10">

    <!-- Cabeçalho -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-3">
        <span class="text-xs uppercase tracking-[0.25em] text-secondary/50 reveal-up inline-flex items-center gap-3">
          <span class="inline-block w-6 h-px bg-primary"></span>
          {label}
        </span>
      </div>
      <h2 class="lg:col-span-9 font-display text-big uppercase">
        <span class="reveal-mask block"><span>{title}</span></span>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
      {items.map((item) => (
        <article
          class="reveal-up bg-secondary text-cream p-8 lg:p-10 rounded-lg transition-transform duration-700 ease-expo hover:-translate-y-2"
          data-stagger-item
        >

          <!-- Aspas decorativas -->
          <svg width="32" height="26" viewBox="0 0 40 32" class="text-primary mb-6" fill="currentColor">
            <path d="M0 32V19.2C0 8.6 5.6 1.4 16.8 0v6.4c-5.6 1.4-8.4 5.2-8.4 11.4H16V32H0zm22.4 0V19.2C22.4 8.6 28 1.4 39.2 0v6.4c-5.6 1.4-8.4 5.2-8.4 11.4h7.6V32H22.4z"/>
          </svg>

          <p class="text-base md:text-lg leading-relaxed mb-8 text-cream/90">
            {item.text}
          </p>

          <!-- Estrelas -->
          <div class="flex gap-1 mb-5" aria-label={`${item.rating} de 5 estrelas`}>
            {Array.from({ length: item.rating }).map(() => (
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="text-primary">
                <path d="M8 1l1.8 3.6L14 5.6l-3 2.9.7 4.1L8 10.5l-3.7 2.1.7-4.1-3-2.9 4.2-.9L8 1z"/>
              </svg>
            ))}
          </div>

          <!-- Autor -->
          <footer class="border-t border-cream/15 pt-4">
            <div class="font-display text-lg uppercase">{item.name}</div>
            {item.role && (
              <div class="text-xs uppercase tracking-widest text-cream/50 mt-1">{item.role}</div>
            )}
          </footer>
        </article>
      ))}
    </div>

  </div>
</section>
