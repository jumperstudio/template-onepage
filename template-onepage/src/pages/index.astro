---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import SocialProof from '../components/SocialProof.astro';
import Gallery from '../components/Gallery.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Footer from '../components/Footer.astro';
import { getEmailUrl, getPhoneUrl, getWhatsappUrl } from '../lib/links';

import data from '../data/client.json';
import content from '../data/content.json';

const whatsappUrl = getWhatsappUrl(data.contact.whatsapp);
const phoneUrl = getPhoneUrl(data.contact.phone);
const emailUrl = getEmailUrl(data.contact.email);

const ctaHref = data.contact.primary_cta === 'whatsapp' && whatsappUrl
  ? whatsappUrl
  : (data.contact.primary_cta === 'phone' && phoneUrl) || emailUrl || '#';

const ctaLabel = data.contact.primary_cta === 'whatsapp'
  ? 'Agendar pelo WhatsApp'
  : data.contact.primary_cta === 'phone'
  ? 'Ligar agora'
  : 'Entrar em contato';

const pageTitle = "Faria & Lima — Itaim Bibi, São Paulo | Advocacia Empresarial";

const marqueeWords = [
  ...data.services.slice(0, 4).map((s) => s.name),
  data.business.city || 'Brasil',
];

const socialProof = data.social_proof || {
  type: 'testimonials',
  testimonials: data.assets.testimonials || [],
  numbers: [],
  process: [],
  faq: [],
};
---

<Base
  title={pageTitle}
  description={data.seo.meta_description}
  businessName={data.business.name}
  address={data.contact.address}
  phone={data.contact.phone}
  keywords={data.seo.keywords}
  fontPair={data.meta.font_pair}
>

  <Hero
    businessName={data.business.name}
    tagline={content.hero.headline}
    shortName={data.business.short_name}
    ctaLabel={ctaLabel}
    ctaHref={ctaHref}
    heroImage={data.assets.photos?.[0]}
    city={data.business.city}
    neighborhood={data.business.neighborhood}
    founded={data.business.founded}
    shortDescription={data.business.short_description}
    logo={data.assets.logo}
  />

  <Marquee words={marqueeWords} variant="light" />

  <Services items={data.services} ctaHref={ctaHref} ctaLabel={ctaLabel} subtitle={content.services_intro} />

  <About
    businessName={data.business.name}
    founded={data.business.founded}
    profile={content.about_text}
    differentials={data.audience.differentials}
    photos={data.assets.photos}
  />

  <SocialProof
    type={socialProof.type}
    testimonials={socialProof.testimonials}
    numbers={socialProof.numbers}
    process={socialProof.process}
    faq={socialProof.faq}
  />

  <Gallery photos={data.assets.photos} businessName={data.business.name} />

  <ContactCTA
    businessName={data.business.name}
    phone={data.contact.phone}
    whatsapp={data.contact.whatsapp}
    email={data.contact.email}
    address={data.contact.address}
    hours={data.contact.hours}
    primaryCta={data.contact.primary_cta}
    social={data.contact.social}
  />

  <Footer
    businessName={data.business.name}
    shortName={data.business.short_name}
    address={data.contact.address}
    phone={data.contact.phone}
    social={data.contact.social}
  />

</Base>